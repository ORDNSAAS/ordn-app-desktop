{
  "name": "ordn-desktop",
  "version": "1.1.6",
  "description": "ORDN OS Desktop - Impresion nativa",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.ordnos.desktop",
    "productName": "ORDN OS",
    "publish": {
      "provider": "github",
      "owner": "ORDNSAAS",
      "repo": "ordn-app-desktop",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "ORDN-Setup.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "artifactName": "ORDN-Setup.dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}
